{
  "name": "Omnibear",
  "version": "2.2.0",
  "description": "A micropub browser extension",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox --mv3",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox --mv3",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox --mv3",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint:check": "eslint . --ext .js,.ts,.jsx,.tsx,.json,.md",
    "lint:fix": "eslint . --fix --ext .js,.ts,.jsx,.tsx,.json,.md",
    "check": "npm run format:check && npm run lint:check",
    "postinstall": "wxt prepare",
    "test": "vitest --run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/keithjgrant/omnibear.git"
  },
  "keywords": [
    "micropub"
  ],
  "author": "Keith J. Grant",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/keithjgrant/omnibear/issues"
  },
  "homepage": "https://omnibear.com",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^2.0.0",
    "@eslint/markdown": "^8.0.2",
    "@preact/preset-vite": "^2.10.3",
    "@types/jsdom": "^28.0.3",
    "@webext-core/fake-browser": "^1.3.4",
    "eslint": "^10.4.0",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.55.0",
    "vitest": "^4.0.18",
    "wxt": "^0.20.26"
  },
  "dependencies": {
    "@aciccarello/micropub-helper": "^3.0.0",
    "@preact/signals": "^2.8.0",
    "microformats-parser": "^2.0.4",
    "preact": "^10.28.3"
  },
  "lint-staged": {
    "*.{css,yaml,yml}": [
      "prettier --write"
    ],
    "*.{js,jsx,ts,tsx,json,md}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
